# Public Firebase Web configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_APP_URL=https://assets.hillkoff.com

# Firebase Admin credentials (prefer workload identity in managed environments)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Google Cloud
GOOGLE_CLOUD_PROJECT=
BIGQUERY_LOCATION=asia-southeast1
BIGQUERY_DATASET_PREFIX=hillkoff_asset
ANALYTICS_PROVIDER=firebase

# Authentication
AUTH_SESSION_COOKIE_NAME=hillkoff_session
AUTH_SESSION_EXPIRES_IN_DAYS=5
USER_INVITATION_EXPIRES_IN_HOURS=72

# Google Workspace SMTP (use an App Password or an approved SMTP relay)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@hillkoff.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@hillkoff.com
SMTP_FROM_NAME=Hillkoff Asset Management
SMTP_REPLY_TO=store-hk@hillkoff.com

# One-time identity migration
IDENTITY_MIGRATION_ACTOR_UID=
